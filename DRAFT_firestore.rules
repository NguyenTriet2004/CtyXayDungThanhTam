rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Phase 3: Primitive Definition ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'triet1509w@gmail.com' || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isServerTimestamp(field) { return incoming()[field] == request.time; }

    // --- Phase 4: Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) && 
             data.email is string && data.email.size() <= 128 &&
             data.role in ['admin', 'user'] &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.createdAt == null || data.createdAt is timestamp);
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'category', 'excerpt', 'content', 'image', 'author', 'createdAt']) &&
             data.title is string && data.title.size() <= 256 &&
             data.category is string && data.category.size() <= 64 &&
             data.excerpt is string && data.excerpt.size() <= 1000 &&
             data.content is string && data.content.size() <= 50000 &&
             data.image is string && data.image.size() <= 2000 &&
             data.author is string && data.author.size() <= 128;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'image', 'year', 'createdAt']) &&
             data.title is string && data.title.size() <= 256 &&
             data.category is string && data.category.size() <= 64 &&
             data.image is string && data.image.size() <= 2000 &&
             data.year is string && data.year.size() <= 4 &&
             (data.description == null || (data.description is string && data.description.size() <= 5000)) &&
             (data.details == null || (data.details is string && data.details.size() <= 20000));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'phone', 'message', 'createdAt']) &&
             data.name is string && data.name.size() <= 128 &&
             data.phone is string && data.phone.size() <= 32 &&
             data.message is string && data.message.size() <= 5000 &&
             (data.service == null || (data.service is string && data.service.size() <= 64));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['name', 'comment', 'rating', 'createdAt']) &&
             data.name is string && data.name.size() <= 128 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             (data.position == null || (data.position is string && data.position.size() <= 128)) &&
             (data.avatar == null || (data.avatar is string && data.avatar.size() <= 2000));
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      // Action: Update Profile
      allow update: if (
        (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])) || 
        isAdmin()
      );
    }

    match /blog/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBlogPost(incoming()) && isServerTimestamp('createdAt');
      allow update: if isAdmin() && isValidBlogPost(incoming());
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProject(incoming()) && isServerTimestamp('createdAt');
      allow update: if isAdmin() && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      // Open to anyone to send enquiries
      allow create: if isValidMessage(incoming()) && isServerTimestamp('createdAt');
      // Secret enquiries - only admins
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAdmin() && isValidReview(incoming()) && isServerTimestamp('createdAt');
      allow update: if isAdmin() && isValidReview(incoming());
      allow delete: if isAdmin();
    }
  }
}
